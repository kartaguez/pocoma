meta {
  name: 02 Delete Pot
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/api/pots/{{potId}}
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
  Content-Type: application/json
}

body:json {
  {
    "expectedVersion": {{potVersion}}
  }
}

script:post-response {
  (() => {
  let body = res.getBody();
  if (typeof body === "string") {
    try { body = JSON.parse(body); } catch (error) { body = null; }
  }
  if (!body || body.status >= 400) {
    return;
  }
  if (body.id) {
    bru.setVar("potId", body.id);
  }
  if (body.version) {
    bru.setVar("potVersion", String(body.version));
  }
  })();
}
