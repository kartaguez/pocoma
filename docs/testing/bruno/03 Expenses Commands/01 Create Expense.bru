meta {
  name: 01 Create Expense
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/pots/{{potId}}/expenses
  body: json
  auth: none
}

headers {
  X-User-Id: {{userId}}
  Content-Type: application/json
}

body:json {
  {
    "payerId": "{{aliceShareholderId}}",
    "amountNumerator": 42,
    "amountDenominator": 1,
    "label": "Lunch Bruno",
    "shares": [
      {
        "shareholderId": "{{aliceShareholderId}}",
        "weightNumerator": 1,
        "weightDenominator": 2
      },
      {
        "shareholderId": "{{bobShareholderId}}",
        "weightNumerator": 1,
        "weightDenominator": 2
      }
    ],
    "expectedVersion": {{potVersion}}
  }
}

script:post-response {
  (() => {
  let body = res.getBody();
  if (typeof body === "string") {
    try { body = JSON.parse(body); } catch (error) { body = null; }
  }
  if (!body || body.status >= 400) {
    return;
  }
  if (body.expenseId) {
    bru.setVar("expenseId", body.expenseId);
  }
  if (body.potId) {
    bru.setVar("potId", body.potId);
  }
  if (body.version) {
    bru.setVar("expenseVersion", String(body.version));
    bru.setVar("potVersion", String(body.version));
  }
  })();
}
